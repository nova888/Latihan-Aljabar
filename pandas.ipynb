        "import pandas as pd\n",
        "\n",
        "#series sederhana\n",
        "tinggi = pd.Series([170, 165, 180, 175])\n",
        "\n",
        "#series dengan label custom\n",
        "nilai = pd.Series(\n",
        "    [85, 90, 78, 92],\n",
        "    index=[\"Matematika\", \"Fisika\", \"Biologi\", \"Kimia\"]\n",
        ")\n",
        "print(nilai)\n",
        "\n",
        "#akses berdasarkan label\n",
        "print(nilai[\"Matematika\"])\n",
        "\n"
      ]
